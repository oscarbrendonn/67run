{
  "name": "67-runner",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "CDN_BUILD=1 npm run build && electron .",
    "dist": "CDN_BUILD=1 npm run build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.sixtyseven.runner",
    "productName": "67 Runner",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [{ "target": "dir", "arch": ["arm64"] }]
    }
  },
  "dependencies": {
    "postprocessing": "^6.36.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
